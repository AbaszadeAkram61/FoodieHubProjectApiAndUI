@model UpdateServiceDtos

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Niyə FoodieHub yeniləmə səhifəsi</h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="UpdateService" method="post">
                            <input type="hidden" asp-for="ServiceId" class="form-control" />
                            <label>Başlıq Adı</label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>Açıqlama</label>
                            <input type="text" asp-for="Description" class="form-control" />
                            <br />
                            <label>İkon  </label>
                            <input type="text" asp-for="IconUrl" class="form-control" />
                            <br />

                            <button class="btn btn-success"> Sahəni yenilə</button>
                        </form>
                    </div>
                </div>


            </div>

        </div>

</section>


