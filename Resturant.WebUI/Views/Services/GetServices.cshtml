@model List< ResultServiceDtos>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    int count = 0;

}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Niyə Foodiehub Bölməsi</h4>

                    </div>
                    <div class="card-body">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th scope="col">#</th>
                                    <th scope="col">Başlıq adı</th>
                                    <th scope="col">Açıqlama</th>
                                    <th scope="col">Sil</th>
                                    <th scope="col">Yenilə</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <th scope="row">@count</th>
                                        <td>@item.Title</td>
                                        <td>@item.Description</td>

                                        <td><a href="/Services/DeleteService/@item.ServiceId" class="btn btn-danger">Sil</a></td>
                                        <td><a href="/Services/UpdateServiceForm/@item.ServiceId" class="btn btn-success">Yenilə</a></td>
                                    </tr>
                                }

                            </tbody>

                            <br />

                            <a href="/Services/CreateServiceForm" class="btn btn-info">Yeni Sahə yarat</a>


                        </table>
                    </div>
                </div>


            </div>

        </div>

</section>

