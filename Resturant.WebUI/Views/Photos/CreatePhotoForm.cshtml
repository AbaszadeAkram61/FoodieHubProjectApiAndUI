@model CreatePhotoDtos

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Şəkil yaratma səhifəsi</h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="CreatePhoto" method="post">
                            <label> Başlıq Adı </label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>Şəkil</label>
                            <input type="text" asp-for="PhotoUrl" class="form-control" />
                            <br />
                            
                            <button class="btn btn-primary"> Şəkil yarat</button>
                        </form>
                    </div>
                </div>


            </div>

        </div>

</section>
