@model UpdatePhotoDtos

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Şəkil yeniləmə səhifəsi</h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="UpdatePhoto" method="post">
                            <input type="hidden" asp-for="PhotoId" class="form-control" />
                            <label> Başlıq Adı </label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>Şəkil</label>
                            <input type="text" asp-for="PhotoUrl" class="form-control" />
                            <br />

                            <button class="btn btn-success"> Şəkil yenilə</button>
                        </form>
                    </div>
                </div>


            </div>

        </div>

</section>

