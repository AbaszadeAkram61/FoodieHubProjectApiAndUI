@model CreateChefDtos

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Aşpaz  yaratma səhifəsi</h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="CreateChef" method="post">
                            <label>Aşpaz Adı</label>
                            <input type="text" asp-for="NameSurname" class="form-control" />
                            <br />
                            <label>Başlıq </label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>Açıqlama </label>
                            <input type="text" asp-for="Description" class="form-control" />
                            <br />
                            <label>Şəkil</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                            <br />

                            <button class="btn btn-primary">Yeni Aşpaz yarat</button>
                        </form>
                    </div>
                </div>


            </div>

        </div>

</section>

