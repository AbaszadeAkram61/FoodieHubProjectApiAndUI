<!DOCTYPE html>
<html lang="en">

@await Component.InvokeAsync("Head")

<body class="index-page">

    @await Component.InvokeAsync("Header")

    <main class="main">

        <!-- Hero Section -->
        @await Component.InvokeAsync("Feature")
        <!-- About Section -->
        @await Component.InvokeAsync("About")
        <!-- /About Section -->
        <!-- Why Us Section -->
        @await Component.InvokeAsync("Service")
        <!-- /Why Us Section -->
        <!-- Stats Section -->
        @await Component.InvokeAsync("Stats")
       <!-- /Stats Section -->
        <!-- Menu Section -->
        @await Component.InvokeAsync("Menu")
       <!-- /Menu Section -->
        <!-- Testimonials Section -->
        @await Component.InvokeAsync("Testimonial")
        <!-- /Testimonials Section -->
        <!-- Events Section -->
        @await Component.InvokeAsync("Event")
        <!-- /Events Section -->
        <!-- Chefs Section -->
        @await Component.InvokeAsync("Chef")
       <!-- /Chefs Section -->
        <!-- Book A Table Section -->
        @await Html.PartialAsync("/Views/Reservations/ReservationFormPartial.cshtml")
       <!-- /Book A Table Section -->
        <!-- Gallery Section -->
        @await Component.InvokeAsync("Galereya")
       <!-- /Gallery Section -->
        <!-- Contact Section -->
       @await Component.InvokeAsync("Contact")

    </main>

    @await Component.InvokeAsync("Footer")

    <!-- Scroll Top -->
    <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center"><i class="bi bi-arrow-up-short"></i></a>

    <!-- Preloader -->
