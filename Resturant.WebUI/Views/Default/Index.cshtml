    <!-- Vendor JS Files -->
    <script src="/yummy-red-1.0.0/assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="/yummy-red-1.0.0/assets/vendor/php-email-form/validate.js"></script>
    <script src="/yummy-red-1.0.0/assets/vendor/aos/aos.js"></script>
    <script src="/yummy-red-1.0.0/assets/vendor/glightbox/js/glightbox.min.js"></script>
    <script src="/yummy-red-1.0.0/assets/vendor/purecounter/purecounter_vanilla.js"></script>
    <script src="/yummy-red-1.0.0/assets/vendor/swiper/swiper-bundle.min.js"></script>

    <!-- Main JS File -->
    <script src="/yummy-red-1.0.0/assets/js/main.js"></script>

</body>

</html>
