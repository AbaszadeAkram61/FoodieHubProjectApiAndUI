@model CreateTestimonialDtos


@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Yeni Müştəri Şərhi yaratma səhifəsi</h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="CreateTestimonial" method="post">
                            <label>Müştəri Adı</label>
                            <input type="text" asp-for="NameSurname" class="form-control" />
                            <br />
                            <label>Müştəri Ünvan</label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>Müştəri Şərhi</label>
                            <input type="text" asp-for="Comment" class="form-control" />
                            <br />
                            <label>Müştəri Şəkli</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                            <br />

                            <button class="btn btn-primary">Yeni Müştəri Şərhi yarat</button>
                        </form>
                    </div>
                </div>


            </div>

        </div>

</section>

