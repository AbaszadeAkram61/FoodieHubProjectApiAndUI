@model CreateProductDtos

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Məhsul yaradilma səhifəsi</h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="CreateProduct" method="post">
                            <label>Məhsul Adı</label>
                            <input type="text" asp-for="ProductName" class="form-control" />
                            <br />
                            <label>Məhsul Qiyməti</label>
                            <input type="number" asp-for="Price" class="form-control" />
                            <br />
                            <label>Kateqoriya Seçin</label>
                            <select asp-for="CategoryId" class="form-control">
                                
                                <option value=""></option>
                                @foreach (var item in ViewBag.Categories)
                                {
                                    <option value="@item.CategoryId">@item.CategoryName</option>
                                }
                            </select>
                            <label>Məhsul Şəkili</label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                            <br />
                            <label>Məhsul Açıxlaması</label>
                            <textarea class="form-control" asp-for="ProductDescription" rows="5"></textarea>
                            <br />
                            <button class="btn btn-primary">Məhsul yarat</button>
                        </form>
                    </div>
                </div>


            </div>

        </div>

</section>

