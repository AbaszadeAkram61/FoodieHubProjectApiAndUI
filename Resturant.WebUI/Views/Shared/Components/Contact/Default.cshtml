@model List<ResultContactDtos>


    <section id="contact" class="contact section">


        <div class="container section-title" data-aos="fade-up">
            <h2>Əlaqə</h2>
            <p><span>Necə Kömək Edə Bilərik?</span> <span class="description-title">Bizimlə Əlaqə Saxlayın</span></p>
        </div>
    @foreach (var item in Model)
    {
        <div class="container" data-aos="fade-up" data-aos-delay="100">


            <div class="mb-5">
                <iframe style="width: 100%; height: 400px;" src="@item.MapLocation" frameborder="0" allowfullscreen=""></iframe>
            </div>

            <div class="row gy-4">

                <div class="col-md-6">
                    <div class="info-item d-flex align-items-center" data-aos="fade-up" data-aos-delay="200">
                        <i class="icon bi bi-geo-alt flex-shrink-0"></i>
                        <div>
                            <h3>Ünvan</h3>
                            <p>@item.Address</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-item d-flex align-items-center" data-aos="fade-up" data-aos-delay="300">
                        <i class="icon bi bi-telephone flex-shrink-0"></i>
                        <div>
                            <h3>Bizimlə Əlaqə</h3>
                            <p>@item.Phone</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-item d-flex align-items-center" data-aos="fade-up" data-aos-delay="400">
                        <i class="icon bi bi-envelope flex-shrink-0"></i>
                        <div>
                            <h3>Email Ünvanımız</h3>
                            <p>@item.Email</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="info-item d-flex align-items-center" data-aos="fade-up" data-aos-delay="500">
                        <i class="icon bi bi-clock flex-shrink-0"></i>
                        <div>
                            <h3>İş Saatlarımız<br></h3>
                            <p><strong>Bazar ertəsi-Şənbə:</strong> "@item.OpenHourse"; <strong>Bazar:</strong> Bağlıdır</p>
                        </div>
                    </div>
                </div>

            </div>


            @await Html.PartialAsync("/Views/Messages/SendMessageForm.cshtml", new CreateMessageDtos())


        </div>
    }
       

    </section>



