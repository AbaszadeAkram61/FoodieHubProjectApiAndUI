@model UpdateCategoryDtos

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Kateqoriya Yeniləmə səhifəsi</h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="UpdateCategory" method="post">
                            <input  type="hidden" asp-for="CategoryId"/>
                            <label>Kateqoriya Adı</label>
                            <input type="text" asp-for="CategoryName" class="form-control" />
                            <br />
                            <button class="btn btn-success">Kateqoriya yenilə</button>
                        </form>
                    </div>
                </div>


            </div>

        </div>

</section>


