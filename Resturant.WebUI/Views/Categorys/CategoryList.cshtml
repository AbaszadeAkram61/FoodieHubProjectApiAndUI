@model List<ResultCategoryDtos>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    int count = 0;
}


    <section class="section">
        <div class="section-body">
            <div class="row">
                <div class="col-12 col-md-12 col-lg-12">
                    <div class="card">
                        <div class="card-header">
                            <h4>Kateqoriya siyahısı</h4>
                        </div>
                        <div class="card-body">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th scope="col">#</th>
                                        <th scope="col">Kateqoriya Adı</th>
                                        <th scope="col">Sil</th>
                                        <th scope="col">Yenilə</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                    count++;
                                    <tr>
                                            <th scope="row">@count</th>
                                            <td>@item.CategoryName</td>
                                            <td><a href="/Categorys/DeleteCategory/@item.CategoryId" class="btn btn-danger">Sil</a></td>
                                            <td><a href="/Categorys/UpdateCategoryForm/@item.CategoryId" class="btn btn-success">Yenilə</a></td>
                                        </tr>
                                    }

                                </tbody>
                            <br />

                            <a href="/Categorys/CreateCategoryForm" class="btn btn-info">Yeni Kateqoriya</a>
                            </table>
                        </div>
                    </div>


                </div>

            </div>
        
    </section>
   


