@model CreateCategoryDtos

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Kateqoriya yaradilma səhifəsi</h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="CreateCategory" method="post">
                          <label>Kateqoriya Adı</label>
                          <input type="text" asp-for="CategoryName"class="form-control"/>
                          <br />
                          <button class="btn btn-primary">Kateqoriya yarat</button>
                      </form>
                    </div>
                </div>


            </div>

        </div>

</section>

