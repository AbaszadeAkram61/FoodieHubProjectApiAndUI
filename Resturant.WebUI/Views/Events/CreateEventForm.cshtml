@model CreateEventDtos


@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Tədbir yaratma səhifəsi</h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="CreateEvent" method="post">
                            <label>Tədbir Başlıq </label>
                            <input type="text" asp-for="Title" class="form-control" />
                            <br />
                            <label>Tədbir Açıqlama</label>
                            <input type="text" asp-for="Description" class="form-control" />
                            <br />
                            <label>Tədbir Şəkil </label>
                            <input type="text" asp-for="ImageUrl" class="form-control" />
                            <br />
                            <label>Tədbir Qiymət </label>
                            <input type="number" asp-for="Price" class="form-control" />
                            <br />
                            <button class="btn btn-primary">Yeni Tədbir yarat</button>
                        </form>
                    </div>
                </div>


            </div>

        </div>

</section>
