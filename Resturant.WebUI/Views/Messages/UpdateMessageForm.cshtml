@model UpdateMessageDtos

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Gələn Mesaj yeniləmə səhifəsi</h4>
                    </div>
                    <div class="card-body">
                        <form asp-action="UpdateMessage" method="post">
                            <input type="hidden" asp-for="MessageId" class="form-control" />
                            <label>Müştəri Adı Soyadı</label>
                            <input type="text" asp-for="NameSurname" class="form-control" />
                            <br />
                            <label>Email </label>
                            <input type="email" asp-for="Email" class="form-control" />
                            <br />
                            <label>Mövzu</label>
                            <input type="text" asp-for="Subject" class="form-control" />
                            <br />
                            <label>Mesaj Detalı</label>
                            <textarea class="form-control" rows="4" asp-for="MessageDetails"></textarea>
                            <br />
                            <label>Göndərmə vaxtı</label>
                            <input type="date" asp-for="SendDate" class="form-control" />
                            <br />
                           
                            <button class="btn btn-success">Gələn Mesajı yenilə</button>
                        </form>
                    </div>
                </div>


            </div>

        </div>

</section>
